// Prisma schema for the Import Cost Calculator.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

/// A stepped/tiered freight pricing method used by the calculator.
model ShippingMethod {
  id                 String   @id @default(cuid())
  name               String
  baseWeightKg       Float
  basePriceCny       Float
  extraPricePerKgCny Float
  roundingMode       String   @default("ceil") // "ceil" | "linear"
  minWeightKg        Float    @default(0)
  maxWeightKg        Float
  etaDays            String?
  // When true the declared (taxable) value defaults to product + freight;
  // when false it defaults to the product value only.
  declaredIncludesFreight Boolean @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

/// A real purchase: one package, possibly shared among several people, whose
/// freight/insurance/taxes are split by weight (rule of three). Shipping method
/// pricing is snapshotted so old purchases stay accurate if a method changes.
model Purchase {
  id   String @id @default(cuid())
  name String

  // Shipping method snapshot.
  methodName              String
  baseWeightKg            Float
  basePriceCny            Float
  extraPricePerKgCny      Float
  roundingMode            String  @default("ceil")
  declaredIncludesFreight Boolean @default(false)

  // Calculation parameters at the time of purchase.
  cnyToBrl         Float
  usdToBrl         Float
  insuranceCny     Float   @default(0)
  importTaxPct     Float   @default(60)
  icmsPct          Float   @default(17)
  marginPct        Float   @default(0)
  exemptionEnabled Boolean @default(false)
  declaredValueUsd Float? // optional package-level declared value override (USD)

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  items     PurchaseItem[]
}

model PurchaseItem {
  id         String   @id @default(cuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  name        String
  category    String?
  person      String? // who the item is for
  weightKg    Float
  priceCny    Float
  imageUrl    String?
  link        String? // product page URL
  // Whether the markup/margin applies to this item (e.g. on for items resold
  // to others, off for your own items).
  applyMargin Boolean @default(true)
}
